# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# PyInstaller / Build / Distribution directories
/build/
/dist/
*.spec
!Ariadne.spec
*.egg-info/
.eggs/

# Unit test / coverage reports & caches
.pytest_cache/
.coverage
htmlcov/
*.cover
*.py,cover
tests/

# Documentation & internal markdown notes (exclude all .md except README.md)
Docs/
*.md
!README.md

# Local OSINT workspaces, Target databases & local vaults
Ariadne_Workspace/
Targets/
*.db
*.sqlite
*.sqlite3

# Local secrets, configurations & environment files
config.json
.env
.env.local
.secrets.*

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# IDE local state & logs
.vscode/
.idea/
*.log
